# Free LLM via OpenRouter — no credit card needed for free-tier models.
#   1. Sign up: https://openrouter.ai/sign-up
#   2. Create a key: https://openrouter.ai/keys
#   3. Paste below as OPENROUTER_API_KEY and restart `npm run dev`.
#
# Default model is the free Llama 3.3 70B. Other free options:
#   meta-llama/llama-3.3-70b-instruct:free
#   google/gemini-2.0-flash-exp:free
#   mistralai/mistral-7b-instruct:free
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Optional. If you run Ollama locally, set the URL/model here.
# OLLAMA_URL=http://localhost:11434/api/generate
# OLLAMA_MODEL=llama3.2
# DISABLE_OLLAMA=1
